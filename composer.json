{
  "name": "locastic/api-platform-translation-bundle",
  "description": "Translation bundle for Api platform based on Sylius translation",
  "license": "MIT",
  "type": "symfony-bundle",
  "authors": [
    {
      "name": "Paula",
      "email": "paula@locastic.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "api-platform/symfony": "^3.4 || ^4.0",
    "doctrine/orm": "^3.0",
    "doctrine/doctrine-bundle": "^2.13 || ^3.0",
    "symfony/translation": "^6.4 || ^7.0 || ^8.0",
    "symfony/dependency-injection": "^6.4 || ^7.0 || ^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^2.2",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan-symfony": "^2.0",
    "phpstan/phpstan-doctrine": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.95"
  },
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Locastic\\ApiPlatformTranslationBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Locastic\\ApiPlatformTranslationBundle\\Tests\\": "tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "2.0-dev"
    }
  },
  "config": {
    "bin-dir": "bin",
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
